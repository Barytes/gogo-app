# Local knowledge-base repository path
KNOWLEDGE_BASE_DIR=../knowledge-base

# Pi SDK integration
PI_NODE_COMMAND=node
# Leave empty / 0 / off / none / false / no to disable Pi RPC read timeout.
PI_TIMEOUT_SECONDS=off
PI_THINKING_LEVEL=medium
# PI_WORKDIR=../knowledge-base
# Desktop build: bundled Pi runtime
# If you keep the runtime inside gogo-app/pi-runtime/, desktop:build will now
# load this from .env automatically.
# GOGO_DESKTOP_PI_BINARY=./pi-runtime/macos-arm64/pi
# Or point at the runtime root and let the build script choose a platform folder.
# GOGO_DESKTOP_PI_RUNTIME_ROOT=./pi-runtime
# Install the SDK in gogo-app with: npm install

# Optional model provider keys
# DASHSCOPE_API_KEY=your-key
# OPENAI_API_KEY=your-key
# ANTHROPIC_API_KEY=your-key
