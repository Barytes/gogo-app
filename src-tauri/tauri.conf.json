{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gogo-app",
  "version": "0.1.0",
  "identifier": "space.aibuilders.gogoapp",
  "build": {
    "beforeDevCommand": "npm run backend:dev",
    "devUrl": "http://127.0.0.1:8000",
    "frontendDist": "../app/frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "../app/": "app",
      "./desktop-runtime-staging/backend/": "backend-runtime",
      "./desktop-runtime-staging/pi/": "pi-runtime",
      "../../knowledge-base/AGENTS.md": "knowledge-base/AGENTS.md",
      "../../knowledge-base/README.md": "knowledge-base/README.md",
      "../../knowledge-base/inbox/": "knowledge-base/inbox",
      "../../knowledge-base/raw/": "knowledge-base/raw",
      "../../knowledge-base/wiki/": "knowledge-base/wiki",
      "../../knowledge-base/schemas/": "knowledge-base/schemas",
      "../../knowledge-base/skills/": "knowledge-base/skills"
    }
  }
}
